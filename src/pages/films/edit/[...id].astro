---
import Layout from "../../../layouts/Layout.astro";
import {
  FilmsGenresOptions,
  type FilmsResponse,
} from "../../../pocketbase-types";
import Multiselect from "@vueform/multiselect";
export const prerender = false;
import SelectPersonnes from "../../../components/SelectPersonnes.vue";
const rawRouteParam = Astro.params.id;
const routeParam = typeof rawRouteParam === "string" ? rawRouteParam : "";
const routeToken = routeParam.split("/").filter(Boolean).at(-1) ?? "";
const parsedId =
  routeToken && !routeToken.startsWith("new")
    ? routeToken.split("-")[0]
    : undefined;

const isCreateMode = !parsedId;
const isLoggedIn = Astro.locals.pb.authStore.isValid;
const userId = Astro.locals.pb.authStore.model?.id ?? null;
const genreOptions = Object.values(FilmsGenresOptions);

const toSlug = (value: unknown) =>
  String(value || "film")
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)+/g, "");

const nameFor = (personne: { id: string; nom?: string; prenom?: string }) => {
  const parts = [personne.prenom, personne.nom].filter(Boolean);
  return parts.length ? parts.join(" ") : personne.id;
};

const toDateInputValue = (value?: string | null) =>
  value ? String(value).slice(0, 10) : "";

let film: FilmsResponse | null = null;
let personnes: Array<{ id: string; nom?: string; prenom?: string }> = [];
let errorMessage = "";

if (isLoggedIn) {
  personnes = await Astro.locals.pb.collection("Personne").getFullList({
    sort: "nom",
    fields: "id,nom,prenom",
  });
}

if (isLoggedIn && parsedId) {
  try {
    film = await Astro.locals.pb.collection("Films").getOne(parsedId);
  } catch (error) {
    errorMessage = error instanceof Error ? error.message : "Film introuvable.";
  }
}

if (Astro.request.method === "POST") {
  if (!isLoggedIn) {
    errorMessage = "Vous devez etre connecte pour modifier ou ajouter.";
  } else {
    const data = await Astro.request.formData();

    const titre = String(data.get("titre") || "").trim();
    const dateSortie = String(data.get("dete_de_sortie") || "").trim();
    const dureMinRaw = String(data.get("dure_min") || "").trim();
    const dureMin = dureMinRaw ? Number(dureMinRaw) : null;
    const synopsis = String(data.get("synopsis") || "").trim();
    const genres = data.getAll("genres").map((v) => String(v));
    const producteur = String(data.get("producteur") || "").trim();
    const realisateur = data.getAll("realisateur").map((v) => String(v));
    const scenariste = data.getAll("scenariste").map((v) => String(v));
    const poster = data.get("poster");

    const payload = {
      titre: titre || null,
      dete_de_sortie: dateSortie || null,
      dure_min: Number.isFinite(dureMin) ? dureMin : null,
      synopsis: synopsis || null,
      genres,
      producteur: producteur || null,
      realisateur,
      scenariste,
      ...(poster instanceof File && poster.size > 0 ? { poster } : {}),
      ...(userId ? { user: userId } : {}),
    };

    try {
      const savedFilm = parsedId
        ? await Astro.locals.pb.collection("Films").update(parsedId, payload)
        : await Astro.locals.pb.collection("Films").create(payload);

      return Astro.redirect(
        `/films/${savedFilm.id}-${toSlug(savedFilm.titre || titre || "film")}`,
      );
    } catch (error) {
      errorMessage =
        error instanceof Error
          ? error.message
          : "Erreur lors de l'enregistrement.";
    }
  }
}
---

<Layout
  pageTitle={`${isCreateMode ? "Ajouter" : "Editer"} un film - PocketBase Cinema`}
>
  <div>
    <h1>{isCreateMode ? "Ajouter un film" : "Edition film"}</h1>
    <a href="/films">Retour a la liste</a>
  </div>

  {
    !isLoggedIn && (
      <p>
        Vous devez vous connecter.
        <a href="/authpassword">Se connecter</a>
      </p>
    )
  }

  {errorMessage && <p>{errorMessage}</p>}

  {
    isLoggedIn && (
      <div>
        {(!parsedId || film) && (
          <form method="post" enctype="multipart/form-data">
            {userId && <input type="hidden" name="user" value={userId} />}

            <label>
              Poster
              <input type="file" name="poster" />
            </label>

            {film?.poster && <p>Poster actuel: {film.poster}</p>}

            <label>
              Titre
              <input type="text" name="titre" value={film?.titre ?? ""} />
            </label>

            <label>
              Date de sortie
              <input
                type="date"
                name="dete_de_sortie"
                value={toDateInputValue(film?.dete_de_sortie)}
              />
            </label>

            <label>
              Duree (min)
              <input
                type="number"
                name="dure_min"
                value={film?.dure_min ?? ""}
              />
            </label>

            <label>
              Synopsis
              <textarea name="synopsis">{film?.synopsis ?? ""}</textarea>
            </label>

            <fieldset>
              <legend>Genres</legend>
              <div>
                {genreOptions.map((opt) => (
                  <label>
                    <input
                      type="checkbox"
                      name="genres"
                      value={opt}
                      checked={film?.genres?.includes(opt) ?? false}
                    />
                    {opt}
                  </label>
                ))}
              </div>
            </fieldset>

            <label>
              Producteur
              <SelectPersonnes
                personnes={personnes}
                client:load
                name="producteur"
              />
              <select name="producteur">
                <option value="">Aucun</option>
                {personnes.map((personne) => (
                  <option
                    value={personne.id}
                    selected={film?.producteur === personne.id}
                  >
                    {nameFor(personne)}
                  </option>
                ))}
              </select>
            </label>

            <fieldset>
              <legend>Realisateur</legend>
              <div>
                {personnes.map((personne) => (
                  <label>
                    <input
                      type="checkbox"
                      name="realisateur"
                      value={personne.id}
                      checked={
                        film?.realisateur?.includes(personne.id) ?? false
                      }
                    />
                    {nameFor(personne)}
                  </label>
                ))}
              </div>
            </fieldset>

            <fieldset>
              <legend>Scenariste</legend>
              <div>
                {personnes.map((personne) => (
                  <label>
                    <input
                      type="checkbox"
                      name="scenariste"
                      value={personne.id}
                      checked={film?.scenariste?.includes(personne.id) ?? false}
                    />
                    {nameFor(personne)}
                  </label>
                ))}
              </div>
            </fieldset>

            <button type="submit">
              {isCreateMode ? "Ajouter" : "Mettre a jour"}
            </button>
          </form>
        )}
      </div>
    )
  }
</Layout>
